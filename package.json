{
  "name": "semola",
  "version": "0.5.2",
  "description": "Zero-dependency TypeScript utilities for Bun. Type-safe APIs, Redis queues, pub/sub, i18n, caching & auth with tree-shakeable imports.",
  "type": "module",
  "exports": {
    "./errors": {
      "import": {
        "types": "./dist/lib/errors/index.d.mts",
        "default": "./dist/lib/errors/index.mjs"
      },
      "require": {
        "types": "./dist/lib/errors/index.d.cts",
        "default": "./dist/lib/errors/index.cjs"
      }
    },
    "./cache": {
      "import": {
        "types": "./dist/lib/cache/index.d.mts",
        "default": "./dist/lib/cache/index.mjs"
      },
      "require": {
        "types": "./dist/lib/cache/index.d.cts",
        "default": "./dist/lib/cache/index.cjs"
      }
    },
    "./i18n": {
      "import": {
        "types": "./dist/lib/i18n/index.d.mts",
        "default": "./dist/lib/i18n/index.mjs"
      },
      "require": {
        "types": "./dist/lib/i18n/index.d.cts",
        "default": "./dist/lib/i18n/index.cjs"
      }
    },
    "./policy": {
      "import": {
        "types": "./dist/lib/policy/index.d.mts",
        "default": "./dist/lib/policy/index.mjs"
      },
      "require": {
        "types": "./dist/lib/policy/index.d.cts",
        "default": "./dist/lib/policy/index.cjs"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/lib/api/index.d.mts",
        "default": "./dist/lib/api/index.mjs"
      },
      "require": {
        "types": "./dist/lib/api/index.d.cts",
        "default": "./dist/lib/api/index.cjs"
      }
    },
    "./queue": {
      "import": {
        "types": "./dist/lib/queue/index.d.mts",
        "default": "./dist/lib/queue/index.mjs"
      },
      "require": {
        "types": "./dist/lib/queue/index.d.cts",
        "default": "./dist/lib/queue/index.cjs"
      }
    },
    "./pubsub": {
      "import": {
        "types": "./dist/lib/pubsub/index.d.mts",
        "default": "./dist/lib/pubsub/index.mjs"
      },
      "require": {
        "types": "./dist/lib/pubsub/index.d.cts",
        "default": "./dist/lib/pubsub/index.cjs"
      }
    },
    "./cron": {
      "import": {
        "types": "./dist/lib/cron/index.d.mts",
        "default": "./dist/lib/cron/index.mjs"
      },
      "require": {
        "types": "./dist/lib/cron/index.d.cts",
        "default": "./dist/lib/cron/index.cjs"
      }
    },
    "./logging": {
      "import": "./dist/lib/logging/index.js",
      "types": "./dist/lib/logging/index.d.ts"
    },
    "./prompts": {
      "import": {
        "types": "./dist/lib/prompts/index.d.mts",
        "default": "./dist/lib/prompts/index.mjs"
      },
      "require": {
        "types": "./dist/lib/prompts/index.d.cts",
        "default": "./dist/lib/prompts/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "biome check --write . && tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "bun",
    "typescript",
    "api-framework",
    "rest-api",
    "type-safe",
    "zero-dependency",
    "utilities",
    "queue",
    "redis",
    "pubsub",
    "caching",
    "cron",
    "scheduler",
    "job-scheduler",
    "i18n",
    "internationalization",
    "authorization",
    "policy",
    "backend",
    "framework",
    "middleware",
    "openapi",
    "validation"
  ],
  "author": "Leonardo Dipace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardodipace/semola.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@standard-schema/spec": "^1.1.0",
    "@types/bun": "latest",
    "openapi-types": "^12.1.3",
    "tsdown": "^0.21.7",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
